# Google Cloud SQL (PostgreSQL) — asyncpg format
# For Cloud SQL Auth Proxy: postgresql+asyncpg://user:password@localhost:5432/nigeriabidb
# For Cloud Run with Unix socket: postgresql+asyncpg://user:password@/nigeriabidb?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nigeriabids

REDIS_URL=redis://redis:6379/0

SECRET_KEY=replace-with-a-long-random-string

# IMAP (for email parsing of tender alerts)
IMAP_HOST=imap.gmail.com
IMAP_USER=your-alert-inbox@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX

# SAM.gov API — get free key at https://api.data.gov/signup/
SAMGOV_API_KEY=DEMO_KEY

# Google Custom Search — https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# Google Gemini API — https://aistudio.google.com/apikey (for AI relevance scoring)
GEMINI_API_KEY=

# SMTP (for sending alert notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_FROM_EMAIL=alerts@yourcompany.com
